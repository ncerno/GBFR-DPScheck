{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GBFR-DPScheck",
  "version": "0.1.0",
  "identifier": "dev.ncerno.gbfr-dpscheck",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GBFR-DPScheck",
        "width": 980,
        "height": 720,
        "transparent": false,
        "decorations": true,
        "alwaysOnTop": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data:; connect-src 'self' ws://127.0.0.1:* ws://localhost:* ws://[::1]:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
